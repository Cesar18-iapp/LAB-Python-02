1.

numeros = [5, 10, 15, 20]

# a. Tuplas (n, n^2)
pares = [(n, n**2) for n in numeros]

# b. Cubos de números mayores a 10
cubos = [n**3 for n in numeros if n > 10]

# c. Números pares
pares_num = [n for n in numeros if n % 2 == 0]

# d. Formato "valor: n"
valores = [f"valor: {n}" for n in numeros]

# e. Celsius a Fahrenheit
celsius = [0, 20, 30, 100]
fahrenheit = [(c * 9/5) + 32 for c in celsius]

# f. Palabras de más de 5 letras
palabras = ["sol", "estrella", "universo", "luz"]
largas = [p for p in palabras if len(p) > 5]

# g. Iniciales de palabras
iniciales = [p[0] for p in palabras]

# h. Etiquetar par/impar
etiquetas = ["par" if n % 2 == 0 else "impar" for n in numeros]

# i. Aplanar matriz
matriz = [[1,2,3],[4,5,6],[7,8,9]]
aplanada = [elem for fila in matriz for elem in fila]
