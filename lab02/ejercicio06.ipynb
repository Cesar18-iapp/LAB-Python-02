import math

# Función minimax
def minimax(piedras, turno_max):
    # Caso base: no quedan piedras
    if piedras == 0:
        return 1 if not turno_max else -1  # gana el que no debía mover
    
    if turno_max:  # turno de MAX (CPU)
        mejor_valor = -math.inf
        for mov in [1, 2, 3]:
            if piedras - mov >= 0:
                valor = minimax(piedras - mov, False)
                mejor_valor = max(mejor_valor, valor)
        return mejor_valor
    else:  # turno de MIN (humano)
        peor_valor = math.inf
        for mov in [1, 2, 3]:
            if piedras - mov >= 0:
                valor = minimax(piedras - mov, True)
                peor_valor = min(peor_valor, valor)
        return peor_valor

# Función para que la CPU elija la mejor jugada
def mejor_jugada(piedras):
    mejor_mov = None
    mejor_valor = -math.inf
    for mov in [1, 2, 3]:
        if piedras - mov >= 0:
            valor = minimax(piedras - mov, False)
            if valor > mejor_valor:
                mejor_valor = valor
                mejor_mov = mov
    return mejor_mov

# Simulación del juego
def jugar_nim(piedras=10):
    turno_humano = True
    while piedras > 0:
        print(f"\nQuedan {piedras} piedras.")
        if turno_humano:
            mov = int(input("Tu turno (quita 1, 2 o 3 piedras): "))
            while mov not in [1,2,3] or mov > piedras:
                mov = int(input("Movimiento inválido. Intenta de nuevo: "))
        else:
            mov = mejor_jugada(piedras)
            print(f"La CPU quita {mov} piedras.")
        piedras -= mov
        turno_humano = not turno_humano
    
    if turno_humano:
        print("¡La CPU gana!")
    else:
        print("¡Tú ganas!")

# Ejecutar
jugar_nim(10)
