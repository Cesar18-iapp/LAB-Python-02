a.
numeros = [1, 2, 3, 4, 5, 6, 7, 8, 9]

pares_cuadrados = list(
    map(lambda x: x**2, filter(lambda n: n % 2 == 0, numeros))
)

print(pares_cuadrados)  # [4, 16, 36, 64]

b.
numeros = [2, 3, 4, 5, 6]

cubos_mayores = list(
    map(str, filter(lambda x: x > 100, map(lambda n: n**3, numeros)))
)

print(cubos_mayores)  # ['125', '216']

c.
numeros = [5, 10, 12, 15, 20, 8]

resultado = sorted(
    map(lambda n: n**2, filter(lambda x: x > 10, numeros)),
    reverse=True
)

print(resultado)  # [400, 225, 144]

