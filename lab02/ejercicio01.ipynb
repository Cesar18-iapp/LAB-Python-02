1.

# a. Múltiplo de 3
multiplo3 = lambda x: x % 3 == 0

# b. Cubo
cubo = lambda x: x**3

# c. Producto de dos números
producto = lambda a, b: a * b

# d. Mayor de dos números
mayor = lambda a, b: a if a > b else b

# e. Empieza con "A" o "a"
empiezaA = lambda palabra: palabra.lower().startswith("a")

# f. Celsius a Fahrenheit
celsius_a_fahrenheit = lambda c: (c * 9/5) + 32

2.

# Lista de lambdas
operaciones = [
    lambda x: x * 2,      # duplicar
    lambda x: x + 10,     # sumar 10
    lambda x: x**2        # cuadrado
]

n = int(input("Ingrese un número: "))
for f in operaciones:
    print(f(n))
