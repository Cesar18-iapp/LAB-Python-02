FILTER
a.
palabras = ["sol", "estrella", "luz", "universo", "mar"]
resultado = list(filter(lambda p: len(p) > 4, palabras))
print(resultado)  # ['estrella', 'universo']

b.
valores = [1, None, 3, None, 5, 7]
resultado = list(filter(lambda x: x is not None, valores))
print(resultado)  # [1, 3, 5, 7]

c.
palabras = ["sol", "estrella", "agua", "universo", "mar"]
resultado = list(filter(lambda p: p[0].lower() in "aeiou", palabras))
print(resultado)  # ['estrella', 'agua', 'universo']

d.
palabras = ["oso", "radar", "sol", "ana", "casa"]
resultado = list(filter(lambda p: p == p[::-1], palabras))
print(resultado)  # ['oso', 'radar', 'ana']

e.
numeros = [10, 25, 35, 42, 55, 60]
resultado = list(filter(lambda n: str(n).endswith("5"), numeros))
print(resultado)  # [25, 35, 55]

f.
productos = [
    {"nombre": "Teclado", "precio": 80},
    {"nombre": "Mouse", "precio": 40},
    {"nombre": "Monitor", "precio": 300},
    {"nombre": "Webcam", "precio": 150}
]

resultado = list(filter(lambda p: p["precio"] > 100, productos))
print(resultado)
# [{'nombre': 'Monitor', 'precio': 300}, {'nombre': 'Webcam', 'precio': 150}]

REDUCE

from functools import reduce

a.
numeros = [2, 3, 4, 5]
producto = reduce(lambda x, y: x * y, numeros)
print(producto)  # 120

b.
palabras = ["Hola", "mundo", "Python", "reduce"]
frase = reduce(lambda x, y: x + " " + y, palabras)
print(frase)  # "Hola mundo Python reduce"

c.
numeros = [10, 25, 7, 99, 42]
mayor = reduce(lambda x, y: x if x > y else y, numeros)
print(mayor)  # 99


SORTED

a.
palabras = ["sol", "estrella", "luz", "universo", "mar"]
ordenadas = sorted(palabras)
print(ordenadas)  # ['estrella', 'luz', 'mar', 'sol', 'universo']

b.
tuplas = [("b", 2), ("a", 5), ("c", 1)]
ordenadas = sorted(tuplas, key=lambda x: x[0])
print(ordenadas)  # [('a', 5), ('b', 2), ('c', 1)]

c.
productos = [
    ("Camisa", 30),
    ("Pantalón", 55),
    ("Medias", 10),
    ("Chaqueta", 80)
]

ordenados = sorted(productos, key=lambda x: (-x[1], x[0]))
print(ordenados)
# [('Chaqueta', 80), ('Pantalón', 55), ('Camisa', 30), ('Medias', 10)]

d.
palabras = ["sol", "estrella", "luz", "universo", "mar"]
ordenadas = sorted(palabras, key=len)
print(ordenadas)  # ['sol', 'luz', 'mar', 'estrella', 'universo']

e.
numeros = [10, 25, 30, 42, 55, 60]
ordenados = sorted(numeros, key=lambda x: x % 2)
print(ordenados)  # [10, 30, 42, 60, 25, 55]

f.
palabra = "programacion"
conteo = {letra: palabra.count(letra) for letra in set(palabra)}
ordenado = dict(sorted(conteo.items()))
print(ordenado)
# {'a': 2, 'c': 1, 'g': 1, 'i': 1, 'm': 1, 'n': 1, 'o': 2, 'p': 1, 'r': 2}

g.
empleados = [
    ("María", "Ventas", 30),
    ("Luis", "Tecnología", 25),
    ("Ana", "Ventas", 25),
    ("Pedro", "Tecnología", 28)
]

ordenados = sorted(empleados, key=lambda x: (x[1], x[2]))
print(ordenados)
# [('Pedro', 'Tecnología', 28), ('Luis', 'Tecnología', 25), ('Ana', 'Ventas', 25), ('María', 'Ventas', 30)]
