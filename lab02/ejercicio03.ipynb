a.
celsius = [0, 20, 30, 100]
fahrenheit = list(map(lambda t: (t * 9/5) + 32, celsius))
print(fahrenheit)  # [32.0, 68.0, 86.0, 212.0]

b.
lista1 = [1, 2, 3]
lista2 = [4, 5, 6]
suma = list(map(lambda x, y: x + y, lista1, lista2))
print(suma)  # [5, 7, 9]

c.
import math
radios = [1, 2, 3, 4]
areas = list(map(lambda r: math.pi * r**2, radios))
print(areas)  # [3.14, 12.57, 28.27, 50.27]

d.
productos = {"pan": 1000, "leche": 2500, "café": 5000}
incremento = list(map(lambda item: (item[0], item[1] * 1.1), productos.items()))
print(incremento)  # [('pan', 1100.0), ('leche', 2750.0), ('café', 5500.0)]

e.
matriz = [[1, 2], [3, 4], [5, 6]]
resultado = list(map(lambda fila: list(map(lambda x: x * 10, fila)), matriz))
print(resultado)  # [[10, 20], [30, 40], [50, 60]]

